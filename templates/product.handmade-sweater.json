        "custom_Kf3KDV": {
          "type": "custom",
          "settings": {
            "code": "<div class=\"bf-box\">\n  <div class=\"bf-inner\">\n    <h2 class=\"bf-title\">HOLIDAY SALE ENDS TONIGHT</h2>\n    <div class=\"bf-sub\">UP TO 80% OFF</div>\n    <p class=\"bf-text\">\n      Now is the time to shop your favourite items at irresistible prices. As long\n      as stocks last!\n    </p>\n  </div>\n</div>\n\n<style>\n  /* ——— Pre-Black Friday Banner ——— */\n  .bf-box{\n    border:1px solid #111;\n    background:#f2f2f2;\n    padding:22px;\n    max-width:980px;\n    margin:0 auto 24px auto;\n  }\n  .bf-inner{\n    text-align:center;\n    font-family:inherit;\n  }\n  .bf-title{\n    margin:0 0 14px 0;\n    font-size:32px;\n    line-height:1.15;\n    letter-spacing:0.5px;\n    font-weight:800;\n    text-transform:uppercase;\n    color:#c43d2f; /* rood zoals voorbeeld */\n  }\n  .bf-sub{\n    margin:0 0 18px 0;\n    font-size:22px;\n    line-height:1.2;\n    font-weight:800;\n    text-transform:uppercase;\n    color:#2b2b2b;\n  }\n  .bf-text{\n    margin:0;\n    font-size:18px;\n    line-height:1.6;\n    color:#60666b; /* zacht grijs */\n  }\n\n  /* Responsive tweaks */\n  @media (max-width: 640px){\n    .bf-box{ padding:18px; }\n    .bf-title{ font-size:24px; }\n    .bf-sub{ font-size:18px; }\n    .bf-text{ font-size:16px; }\n  }\n</style>"
