        "custom_96mLeP": {
          "type": "custom",
          "disabled": true,
          "settings": {
            "code": "<div class=\"fit-container\">\n\n  <div class=\"fit-title\">Fit</div>\n\n  <div class=\"fit-bar\">\n    <div class=\"fit-segment active\"></div>\n    <div class=\"fit-segment active\"></div>\n    <div class=\"fit-segment active\"></div>\n    <div class=\"fit-segment\"></div>\n    <div class=\"fit-segment\"></div>\n  </div>\n\n  <div class=\"fit-labels\">\n    <span>Runs small</span>\n    <span>True to size</span>\n    <span>Runs big</span>\n  </div>\n\n</div>\n\n<style>\n.fit-container {\n  width: 100%;\n  max-width: 500px;\n  margin: 20px 0;\n  font-family: inherit;\n}\n\n.fit-title {\n  font-size: 16px;\n  font-weight: 600;\n  margin-bottom: 8px;\n}\n\n.fit-bar {\n  display: grid;\n  grid-template-columns: repeat(5, 1fr);\n  gap: 6px;\n  margin-bottom: 8px;\n}\n\n.fit-segment {\n  height: 3px;\n  background-color: #e5e5e5;\n  border-radius: 2px;\n}\n\n.fit-segment.active {\n  background-color: #000000;\n}\n\n.fit-labels {\n  display: flex;\n  justify-content: space-between;\n  font-size: 14px;\n  margin-top: 4px;\n}\n\n.fit-labels span:nth-child(2) {\n  flex: 1;\n  text-align: center;\n}\n</style>"
