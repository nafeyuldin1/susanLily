    "text_and_image_JCGFRF": {
      "type": "text-and-image",
      "name": "t:sections.text-and-image.presets.image_with_text.name",
      "settings": {
        "image": "shopify://shop_images/Ontwerp_zonder_titel_4.webp",
        "image_mask": "none",
        "image2_mask": "none",
        "subtitle": "",
        "title": "30-DAY MONEY-BACK GUARANTEE",
        "text": "<p>If your order isn’t quite right, simply return it within <strong>30 days</strong> for a full refund. No fuss, no worry — shopping with Ella & Rose is always stress-free.</p><p>Because we know what matters most: feeling good, looking lovely, and trusting the brands we choose.</p>",
        "button_label": "",
        "button_link": "",
        "button_style": "primary",
        "align_text": "left",
        "image_width": "50",
        "layout": "right",
        "divider": false,
