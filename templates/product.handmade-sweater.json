        "lazyload_images": true
      }
    },
    "ss_testimonial_12_kfT8hA": {
      "type": "ss-testimonial-12",
      "blocks": {
        "slide_qnYhLM": {
          "type": "slide",
          "settings": {
            "media_style": "image",
            "video_url": "",
            "controls": false,
            "stars_count": 5,
            "text": "<p>Wore this dress to a party and got so many compliments! It fits perfectly and feels super comfortable. I’m really happy with it — definitely one of my new favorites!</p>",
            "author": "<p>KATY M.</p>"
          }
        },
        "slide_R8y7nM": {
          "type": "slide",
          "settings": {
            "media_style": "image",
            "video_url": "",
            "controls": false,
            "stars_count": 5,
            "text": "<p>First received the wrong size, and I sent them an email and they immediately sent a new one. Good customer support.</p>",
            "author": "<p>KAREN H.</p>"
          }
        },
        "slide_G7JjkA": {
          "type": "slide",
          "settings": {
            "media_style": "image",
            "video_url": "",
            "controls": false,
            "stars_count": 5,
            "text": "<p>I took advantage of the clearance sale. My order came quickly and quality is good. I will order here more often if the sale is still here!</p>",
            "author": "<p>MICHELLE L.</p>"
          }
        },
        "slide_t7WcFq": {
          "type": "slide",
          "settings": {
            "media_style": "image",
            "video_url": "",
            "controls": false,
            "stars_count": 4,
            "text": "<p>Great fit of the clothes and the quality is good! Use it daily for already 6 months and still super good. Highly recommended.</p>",
            "author": "<p>WENDY Q.</p>"
          }
        },
        "slide_qNtb4b": {
          "type": "slide",
          "settings": {
            "media_style": "image",
            "video_url": "",
            "controls": false,
            "stars_count": 5,
            "text": "<p>Absolutely love this jacket! The fit is super flattering and it feels really high quality. Wore it to dinner last weekend and got so many compliments — I’ll definitely be wearing it a lot more!</p>",
            "author": "<p>SUSAN D.</p>"
          }
        }
      },
