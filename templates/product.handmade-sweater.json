        "custom_zNAEFE": {
          "type": "custom",
          "settings": {
            "code": "<style>\n.custom-shipping-container {\n  display: flex;\n  padding: 6px 16px;\n  justify-content: space-between;\n  align-items: center;\n  align-self: stretch;\n  background-color: #f6f6f6;\n  border-radius: 999px;\n}\n\n.custom-shipping-item {\n  display: flex;\n  align-items: center;\n  gap: 6px;\n}\n\n.text-block-shipping {\n  font-size: 10px;\n  color: #000;\n}\n\n.shipping-date {\n  font-weight: bold;\n}\n\n.free-shipping {\n  font-weight: bold;\n}\n\n.green-circle {\n  animation: fade 1s ease-in-out infinite;\n}\n\n/* Ronde vlag-icoon */\n.usa-flag-icon {\n  display: inline-block;\n  vertical-align: middle;\n}\n\n/* Fade animatie voor groene dot */\n@keyframes fade {\n  0%, 100% { opacity: 1; }\n  50% { opacity: 0.5; }\n}\n</style>\n\n<script>\ndocument.addEventListener(\"DOMContentLoaded\", function() {\n  var daysAfterToday = 0.5; \n  var today = new Date();\n  var shipDate = new Date(today.setDate(today.getDate() + daysAfterToday));\n  var options = { weekday: 'short', month: 'short', day: 'numeric' }; // Mon, Nov 17\n\n  var formattedDate = shipDate.toLocaleDateString('en-US', options);\n  document.getElementById('shipping-date').textContent = formattedDate;\n});\n</script>\n\n<div class=\"custom-shipping-container\">\n  <!-- LINKERKANT: verzenddatum -->\n  <div class=\"custom-shipping-item\">\n    <svg class=\"green-circle\" xmlns=\"http://www.w3.org/2000/svg\" width=\"12\" height=\"13\" viewBox=\"0 0 12 13\" fill=\"none\">\n      <circle cx=\"6\" cy=\"6.5\" r=\"6\" fill=\"#137333\"/>\n    </svg>\n    <div class=\"text-block-shipping\">\n      Ships on <span id=\"shipping-date\" class=\"shipping-date\"></span>\n    </div>\n  </div>\n\n  <!-- RECHTERKANT: ronde USA vlag + tekst -->\n  <div class=\"custom-shipping-item\">\n    <!-- Ronde USA vlag -->\n    <svg class=\"usa-flag-icon\" xmlns=\"http://www.w3.org/2000/svg\" width=\"14\" height=\"14\" viewBox=\"0 0 14 14\">\n      <defs>\n        <clipPath id=\"usa-circle\">\n          <circle cx=\"7\" cy=\"7\" r=\"7\" />\n        </clipPath>\n      </defs>\n      <g clip-path=\"url(#usa-circle)\">\n        <!-- rode achtergrond -->\n        <rect width=\"14\" height=\"14\" fill=\"#b22234\" />\n        <!-- witte strepen (simpel, klein icoon) -->\n        <rect y=\"1\" width=\"14\" height=\"1\" fill=\"#ffffff\" />\n        <rect y=\"3\" width=\"14\" height=\"1\" fill=\"#ffffff\" />\n        <rect y=\"5\" width=\"14\" height=\"1\" fill=\"#ffffff\" />\n        <rect y=\"7\" width=\"14\" height=\"1\" fill=\"#ffffff\" />\n        <rect y=\"9\" width=\"14\" height=\"1\" fill=\"#ffffff\" />\n        <rect y=\"11\" width=\"14\" height=\"1\" fill=\"#ffffff\" />\n        <!-- blauw vlak -->\n        <rect width=\"7\" height=\"7\" fill=\"#3c3b6e\" />\n      </g>\n    </svg>\n\n    <div class=\"text-block-shipping\">\n      <span class=\"free-shipping\">FREE</span> fast delivery\n    </div>\n  </div>\n</div>"
          }
