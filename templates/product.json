        "custom_TN9C7q": {
          "type": "custom",
          "settings": {
            "code": "<div class=\"product-block\">\n                      <div class=\"product-block\">\n                      <div class=\"product-block\">\n  <div style=\"margin: 20px 0; padding: 16px; border: 1px solid #c62828; border-radius: 6px; background-color: #fff5f5; color: #b71c1c; text-align: center;\">\n    \n    <p style=\"margin: 0; font-weight: 700; font-size: 15px; letter-spacing: 0.5px; text-transform: uppercase;\">\n      <svg role=\"presentation\" width=\"18\" height=\"18\" style=\"vertical-align:-3px; margin-right:6px;\" fill=\"none\" stroke=\"#b71c1c\" stroke-width=\"1.5\" viewBox=\"0 0 24 24\">\n        <path d=\"M12 22.4A8.9 8.9 0 1 0 12 4.7a8.9 8.9 0 0 0 0 17.8Z\" fill=\"#b71c1c\" fill-opacity=\".12\" stroke-linecap=\"round\" stroke-linejoin=\"round\"></path>\n        <path d=\"M12 8.8v4.8h4\" stroke-linecap=\"round\" stroke-linejoin=\"round\"></path>\n      </svg>\n      REVIVAL SALE:\n    </p>\n\n    <p style=\"margin: 8px 0 0; font-size: 14px; line-height: 1.5;\">\n      Due to the high order volume, our stock is very limited...<br>\n      If you are still able to press the <strong>'Add to Cart'</strong> button, there's still some stock left!\n    </p>\n\n  </div>\n</div>\n                    </div>\n                    </div>"
