        "custom_zNAEFE": {
          "type": "custom",
          "settings": {
            "code": "<style>\n.custom-shipping-container {\n  display: flex;\n  padding: 6px 16px;\n  justify-content: space-between;\n  align-items: center;\n  align-self: stretch;\n  background-color: #f6f6f6;\n  border-radius: 999px;\n}\n\n.custom-shipping-item {\n  display: flex;\n  align-items: center;\n  gap: 6px;\n}\n\n.text-block-shipping {\n  font-size: 11px;\n  color: #000;\n}\n\n.shipping-date {\n  font-weight: bold;\n}\n\n.free-shipping {\n  font-weight: bold;\n}\n\n.green-circle {\n  animation: fade 1s ease-in-out infinite;\n}\n\n.flag-icon {\n  width: 14px;\n  height: 14px;\n  display: inline-block;\n  vertical-align: middle;\n  border-radius: 50%;\n  object-fit: cover;\n}\n\n@keyframes fade {\n  0%, 100% { opacity: 1; }\n  50% { opacity: 0.5; }\n}\n</style>\n\n<script>\ndocument.addEventListener(\"DOMContentLoaded\", function () {\n  var shipDate = new Date();\n  var day = shipDate.getDay(); // 0 = zondag, 6 = zaterdag\n\n  if (day === 6) {\n    // Zaterdag besteld → maandag\n    shipDate.setDate(shipDate.getDate() + 2);\n  } else if (day === 0) {\n    // Zondag besteld → maandag\n    shipDate.setDate(shipDate.getDate() + 1);\n  } else {\n    // Maandag t/m vrijdag → volgende dag\n    shipDate.setDate(shipDate.getDate() + 1);\n  }\n\n  var formattedDate = shipDate.toLocaleDateString('en-CA', {\n    weekday: 'short',\n    month: 'short',\n    day: 'numeric'\n  });\n\n  document.getElementById('shipping-date').textContent = formattedDate;\n});\n</script>\n\n<div class=\"custom-shipping-container\">\n  <!-- LINKERKANT -->\n  <div class=\"custom-shipping-item\">\n    <svg class=\"green-circle\" xmlns=\"http://www.w3.org/2000/svg\" width=\"12\" height=\"13\" viewBox=\"0 0 12 13\">\n      <circle cx=\"6\" cy=\"6.5\" r=\"6\" fill=\"#137333\"/>\n    </svg>\n    <div class=\"text-block-shipping\">\n      Shipped on <span id=\"shipping-date\" class=\"shipping-date\"></span>\n    </div>\n  </div>\n\n  <!-- RECHTERKANT -->\n  <div class=\"custom-shipping-item\">\n    <img \n      src=\"https://cdn.shopify.com/s/files/1/0919/0532/7438/files/flag-round-250.png?v=1771451015\" \n      alt=\"Canada Flag\"\n      class=\"flag-icon\"\n    />\n    <div class=\"text-block-shipping\">\n      <span class=\"free-shipping\">FREE</span> Shipping\n    </div>\n  </div>\n</div>"
          }
