        "custom_96mLeP": {
          "type": "custom",
          "disabled": true,
          "settings": {
            "code": "<div class=\"fit-container\">\n\n  <div class=\"fit-title\">Fit</div>\n\n  <div class=\"fit-bar\">\n    <div class=\"fit-segment\"></div>\n    <div class=\"fit-segment\"></div>\n    <div class=\"fit-segment active\"></div>\n    <div class=\"fit-segment\"></div>\n    <div class=\"fit-segment\"></div>\n  </div>\n\n  <div class=\"fit-labels\">\n    <span>Small</span>\n    <span>True to size</span>\n    <span>Large</span>\n  </div>\n\n</div>\n\n<style>\n.fit-container {\n  width: 100%;\n  max-width: 500px;\n  margin: 20px 0;\n  font-family: inherit;\n}\n\n.fit-title {\n  font-size: 16px;\n  font-weight: 600;\n  margin-bottom: 8px;\n}\n\n.fit-bar {\n  display: grid;\n  grid-template-columns: repeat(5, 1fr);\n  gap: 6px;\n  margin-bottom: 8px;\n}\n\n.fit-segment {\n  height: 3px;\n  background-color: #e5e5e5;\n  border-radius: 2px;\n}\n\n.fit-segment.active {\n  background-color: #000000;\n}\n\n.fit-labels {\n  display: flex;\n  justify-content: space-between;\n  font-size: 14px;\n  margin-top: 4px;\n}\n\n.fit-labels span:nth-child(2) {\n  flex: 1;\n  text-align: center;\n}\n</style>"
          }
        },
        "custom_bRqHPE": {
          "type": "custom",
          "settings": {
            "code": "<div class=\"product-block\">\n                      <div style=\"border: 1px solid #ddd; padding: 16px; border-radius: 0px; text-align: center; width: 100%; max-width: px; margin: 20px auto; font-family: font-family: inherit;\">\n  <h4 style=\"font-size: 14px; font-weight: bold; margin-bottom: 15px; text-transform: uppercase;\">HOW DOES IT FIT?</h4>\n  <div style=\"display: flex; align-items: center; justify-content: space-between; margin: 10px 0;\">\n    <span style=\"font-size: 14px; color: #555;\">Small</span>\n    <div style=\"position: relative; flex-grow: 1; height: 4px; background-color: #ddd; margin: 0 10px; border-radius: 2px;\">\n      <div style=\"position: absolute; top: -6px; left: 50%; width: 14px; height: 14px; background-color: black; border-radius: 50%; cursor: pointer;\"></div>\n    </div>\n    <span style=\"font-size: 14px; color: #555;\">Large</span>\n  </div>\n  <p style=\"margin-top: 10px; font-size: 14px; color: #555;\">Fits true to size</p>\n</div>\n                    </div>"
          }
        },
        "tab_YFJFMm": {
          "type": "tab",
          "settings": {
            "title": "FREE PREMIUM SHIPPING",
            "content": "<p>We ship all orders with a tracking code, allowing you to track your parcel at any time. You will receive the tracking code via email within 24 hours of placing your order. Shipping within Canada is free of charge.</p>",
            "page": ""
          }
        },
        "tab_8fT6r7": {
          "type": "tab",
          "settings": {
            "title": "30-day money-back guarantee",
            "content": "<p>Not sure if it’s right for you? We get it. While we can tell you all about it, the best way to know is by trying it for yourself. That’s why we offer a risk-free, 30-day money-back guarantee on every order. If you’re not completely satisfied, just return the product, and we’ll issue a full refund!</p>",
            "page": ""
          }
        },
        "tab_fhF3Px": {
          "type": "tab",
          "settings": {
            "title": "SECURE CHECKOUT",
            "content": "<p>We offer a range of secure and convenient payment methods to make your shopping experience seamless. Here’s what we currently accept:</p><ul><li><strong>Credit or Debit Cards:</strong> We welcome all major credit and debit cards, including Visa and Mastercard.</li><li><strong>Mobile Payment Services:</strong> You can also use Apple Pay, Shop Pay, or Google Pay for a quick and easy checkout.</li><li><strong>Gift Cards or Store Credit:</strong> Have a gift card or store credit from us? You can use it towards your purchase.</li></ul>",
            "page": ""
          }
        },
