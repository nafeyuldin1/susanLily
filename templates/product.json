        "custom_JDbkQW": {
          "type": "custom",
          "disabled": true,
          "settings": {
            "code": "<div class=\"product-block product-block--sales-point product-block--stock\">\n  <ul class=\"sales-points\">\n\n    <!-- Knipperend bolletje + voorraad -->\n    <li class=\"sales-point\">\n      <span class=\"icon-and-text\">\n        <div class=\"nl_voorraad\">\n          <span class=\"rood_icoon icoon--voorraad\"></span>\n        </div>\n        <span class=\"random-number\">\n          Only <span id=\"stockNumber\">4</span> left in stock!\n        </span>\n      </span>\n    </li>\n\n  </ul>\n</div>\n\n<style>\n/* Alleen voor deze block */\n.product-block--stock {\n  margin: 0 !important;\n  padding: 0 !important;\n}\n.product-block--stock .sales-points {\n  list-style: none;\n  padding: 0 !important;\n  margin: 0 !important;\n}\n.product-block--stock .sales-point {\n  display: flex;\n  align-items: center;\n  margin: 0 !important;\n  padding: 0 !important;\n}\n.product-block--stock .icon-and-text {\n  display: flex;\n  align-items: center;\n  gap: 8px;\n}\n\n/* Knipperende rode dot (zelfde als eerst) */\n@keyframes voorraad-pulse {\n  0%   { opacity: 0.5; }\n  100% { transform: scale(3.0); opacity: 0; }\n}\n\n.product-block--stock span.rood_icoon {\n  display: inline-block;\n  position: relative;\n  height: 25px;\n  width: 25px;\n  margin-left: 2px;\n}\n\n.product-block--stock .icoon--voorraad:before {\n  animation: voorraad-pulse 2s linear infinite;\n}\n\n.product-block--stock .icoon--voorraad:after,\n.product-block--stock .icoon--voorraad:before {\n  width: 9px;\n  height: 9px;\n  background: #FF0000;\n  border-radius: 9px;\n  position: absolute;\n  left: 0;\n  top: 0;\n  content: \"\";\n  margin: 8px;\n}\n\n.product-block--stock .random-number {\n  margin: 0;            /* geen extra witruimte */\n  line-height: 1.2;\n}\n\n.product-block--stock .nl_voorraad {\n  display: flex;\n  align-items: center;\n  letter-spacing: -.5px;\n}\n\n/* Mobile */\n@media (max-width: 768px) {\n  .product-block--stock {\n    justify-content: flex-start;\n    text-align: left;\n  }\n  .product-block--stock .sales-point {\n    justify-content: flex-start;\n  }\n}\n</style>\n\n<script>\nfunction generateRandomNumber() {\n  var numbers = [4, 5, 6];\n  var randomIndex = Math.floor(Math.random() * numbers.length);\n  document.getElementById(\"stockNumber\").textContent = numbers[randomIndex];\n}\ngenerateRandomNumber();\n</script>"
          }
