            "code": "<!-- Revival Extra Discount block (updated weights) -->\n<div class=\"clearance-extra-discount\">\n  <div class=\"ced-title\">SAVE OUR DREAM SALE</div>\n\n  <div class=\"ced-pair\">\n    <div class=\"ced-add\">\n      <strong>Add 2 items</strong> <span class=\"ced-regular\">to your cart</span>\n    </div>\n    <div class=\"ced-get\">\n      <span class=\"ced-regular\">Get</span> <strong>10% OFF</strong>\n    </div>\n  </div>\n\n  <div class=\"ced-pair\">\n    <div class=\"ced-add\">\n      <strong>Add 3 items</strong> <span class=\"ced-regular\">to your cart</span>\n    </div>\n    <div class=\"ced-get\">\n      <span class=\"ced-regular\">Get</span> <strong>15% OFF</strong>\n    </div>\n  </div>\n\n  <div class=\"ced-pair\">\n    <div class=\"ced-add\">\n      <strong>Add 4 items</strong> <span class=\"ced-regular\">to your cart</span>\n    </div>\n    <div class=\"ced-get\">\n      <span class=\"ced-regular\">Get</span> <strong>20% OFF</strong>\n    </div>\n  </div>\n\n  <div class=\"ced-pair\">\n    <div class=\"ced-add\">\n      <strong>Add 5 items</strong> <span class=\"ced-regular\">to your cart</span>\n    </div>\n    <div class=\"ced-get\">\n      <span class=\"ced-regular\">Get</span> <strong>25% OFF</strong>\n    </div>\n  </div>\n</div>\n\n<style>\n  .clearance-extra-discount{\n    background:#e9e8e4;\n    padding:18px 16px;\n    text-align:center;\n    font-family: inherit;\n    color:#000;\n  }\n\n  .ced-title{\n    font-weight:800;\n    font-size:14px;\n    letter-spacing:1.4px;\n    text-transform:uppercase;\n    margin-bottom:14px;\n  }\n\n  .ced-pair{\n    margin-bottom:10px;\n  }\n\n  .ced-add,\n  .ced-get{\n    font-size:13px;\n    line-height:1.15;\n  }\n\n  .ced-regular{\n    font-weight:400;\n  }\n\n  .ced-get strong{\n    letter-spacing:0.5px;\n  }\n</style>"
          }
