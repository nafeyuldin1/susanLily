          "settings": {
            "code": "<div class=\"product-size-stock\" id=\"SizeStock-variant_picker-15347129581953\" aria-live=\"polite\" data-stock-initialized=\"true\">\n  <div class=\"product-size-stock__header\">\n    <span class=\"product-size-stock__dot\" style=\"opacity: 1;\"></span>\n    <span class=\"product-size-stock__text\"><strong data-size-stock-count=\"\">4</strong> items available</span>\n  </div>\n  <div class=\"product-size-stock__bar\">\n    <span class=\"product-size-stock__fill\" data-size-stock-fill=\"\" style=\"width: 40%;\"></span>\n  </div>\n</div>\n\n<style>\n  #SizeStock-variant_picker-15347129581953 {\n    margin-top: 14px;\n  }\n\n  #SizeStock-variant_picker-15347129581953 .product-size-stock__header {\n    display: flex;\n    align-items: center;\n    gap: 8px;\n    margin-bottom: 8px;\n    color: #111;\n    font-size: 13px;\n    line-height: 1.3;\n  }\n\n  #SizeStock-variant_picker-15347129581953 .product-size-stock__dot {\n    width: 9px;\n    height: 9px;\n    border-radius: 50%;\n    background: #d62828;\n    flex-shrink: 0;\n    box-shadow: 0 0 0 0 rgba(214, 40, 40, 0.35);\n    animation: size-stock-pulse 1.8s ease-out infinite;\n  }\n\n  #SizeStock-variant_picker-15347129581953 .product-size-stock__bar {\n    height: 4px;\n    background: #ececec;\n    border-radius: 999px;\n    overflow: hidden;\n  }\n\n  #SizeStock-variant_picker-15347129581953 .product-size-stock__fill {\n    display: block;\n    height: 100%;\n    width: 0;\n    background: linear-gradient(90deg, #565656 0%, #000 100%);\n    border-radius: inherit;\n    transition: width 0.35s ease;\n  }\n\n  @keyframes size-stock-pulse {\n    0% { box-shadow: 0 0 0 0 rgba(214, 40, 40, 0.35); }\n    70% { box-shadow: 0 0 0 8px rgba(214, 40, 40, 0); }\n    100% { box-shadow: 0 0 0 0 rgba(214, 40, 40, 0); }\n  }\n</style>\n\n<script>\n(function() {\n  function hashString(value) {\n    var hash = 0;\n    for (var i = 0; i < value.length; i++) {\n      hash = ((hash << 5) - hash) + value.charCodeAt(i);\n      hash |= 0;\n    }\n    return Math.abs(hash);\n  }\n\n  function getVariantStockCount(variant) {\n    if (!variant || variant.available === false) return 0;\n    var seed = String(variant.id || variant.title || '');\n    return (hashString(seed) % 3) + 4; // Voorraad 4–6\n  }\n\n  function getCurrentVariant(root) {\n    var section = root.closest('.product-section');\n    if (!section) return null;\n\n    var variantJson = section.querySelector('[data-variant-json]');\n    if (!variantJson) return null;\n\n    var variants;\n    try { variants = JSON.parse(variantJson.textContent); } catch { return null; }\n\n    var selectedVariantInput = section.querySelector('[data-product-select]');\n    if (selectedVariantInput && selectedVariantInput.value) {\n      var selectedVariantId = String(selectedVariantInput.value);\n      for (var i = 0; i < variants.length; i++) {\n        if (String(variants[i].id) === selectedVariantId) return variants[i];\n      }\n    }\n\n    var selectedOptions = [];\n    var optionWrappers = root.parentNode.querySelectorAll('.variant-input-wrap');\n    optionWrappers.forEach(function(wrapper) {\n      var checkedInput = wrapper.querySelector('input[data-variant-input]:checked');\n      var selectedOption = checkedInput ? checkedInput.value : '';\n      if (!selectedOption) {\n        var selectInput = wrapper.querySelector('select[data-variant-input]');\n        selectedOption = selectInput ? selectInput.value : '';\n      }\n      selectedOptions.push(selectedOption);\n    });\n\n    for (var j = 0; j < variants.length; j++) {\n      var variant = variants[j];\n      var matches = true;\n      for (var k = 0; k < selectedOptions.length; k++) {\n        if (selectedOptions[k] && variant.options[k] !== selectedOptions[k]) {\n          matches = false;\n          break;\n        }\n      }\n      if (matches) return variant;\n    }\n    return null;\n  }\n\n  function updateSizeStockBar(root) {\n    if (!root) return;\n\n    var count = getVariantStockCount(getCurrentVariant(root));\n    var fill = root.querySelector('[data-size-stock-fill]');\n    var label = root.querySelector('[data-size-stock-count]');\n    var text = root.querySelector('.product-size-stock__text');\n    var dot = root.querySelector('.product-size-stock__dot');\n\n    if (label) label.textContent = count;\n    if (text) text.innerHTML = '<strong data-size-stock-count>' + count + '</strong> items available';\n\n    if (fill) {\n      // Alleen de balkbreedte aanpassen (30–55% bij voorraad 4–6)\n      var minWidth = 30; // count = 4\n      var maxWidth = 55; // count = 6\n      var width = minWidth + ((count - 4) / (6 - 4)) * (maxWidth - minWidth);\n      fill.style.width = width + '%';\n    }\n\n    if (dot) dot.style.opacity = count > 0 ? '1' : '0.45';\n  }\n\n  function initSizeStockBar() {\n    var root = document.getElementById('SizeStock-variant_picker-15347129581953');\n    if (!root) return;\n\n    if (root.dataset.stockInitialized !== 'true') {\n      root.dataset.stockInitialized = 'true';\n\n      var blockRoot = root.parentNode;\n      if (blockRoot) {\n        blockRoot.addEventListener('change', function(event) {\n          if (event.target.matches('[data-variant-input], [data-product-select]')) {\n            updateSizeStockBar(root);\n          }\n        });\n      }\n\n      var section = root.closest('.product-section');\n      if (section) {\n        section.addEventListener('change', function(event) {\n          if (event.target.matches('[data-variant-input], [data-product-select]')) {\n            updateSizeStockBar(root);\n          }\n        });\n      }\n    }\n\n    updateSizeStockBar(root);\n  }\n\n  if (document.readyState === 'loading') {\n    document.addEventListener('DOMContentLoaded', initSizeStockBar, { once: true });\n  } else {\n    initSizeStockBar();\n  }\n\n  document.addEventListener('shopify:section:load', initSizeStockBar);\n  document.addEventListener('shopify:block:select', initSizeStockBar);\n})();\n</script>"
