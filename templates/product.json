    "faq_CVYnEB": {
      "type": "faq",
      "blocks": {
        "question_8NfbQX": {
          "type": "question",
          "settings": {
            "title": "Do you offer free shipping?",
            "text": "<p>Yes, we offer Free Premium Shipping, along with Track & Trace, because we value you as a customer and want to provide you with the best service.</p>"
          }
        },
        "question_N4EmpG": {
          "type": "question",
          "settings": {
            "title": "Can I return the item(s) if I don’t like them?",
            "text": "<p>Yes, you can return your order within 30 days of receiving it.</p>"
          }
        },
        "question_Ph47ka": {
          "type": "question",
          "settings": {
            "title": "How can I track my order?",
            "text": "<p>You can track your order by entering the tracking number you received from us on the \"TRACK YOUR ORDER\" page. Once you’ve entered the number and clicked \"TRACK,\" you will see the status of your order.</p>"
          }
        },
        "question_wmAkCL": {
          "type": "question",
          "settings": {
            "title": "Is my payment secure?",
            "text": "<p>Yes, your payment is fully secure with SSL encryption. Pay safely with Credit Card, Visa, Mastercard, American Express, Apple Pay, Google Pay, Maestro, or Shop Pay.</p>"
          }
        },
        "question_H4qrgn": {
          "type": "question",
          "settings": {
            "title": "Will I receive a confirmation email after placing an order?",
            "text": "<p>Yes, once you've placed your order, a confirmation will be sent to your email inbox. If you don’t see it, feel free to reach out to our customer service team, we’re happy to help you right away.<br/><br/>Email:  info@susanandlily.com</p>"
          }
        }
      },
