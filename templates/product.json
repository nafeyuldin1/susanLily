        "liquid_GpiEVH": {
          "type": "liquid",
          "settings": {
            "code": "<style>\n\n\n\n.content-block{\n  display:flex;\nalign-items:center;\n\n\n}\n\n\n.icon-wrapper>img{\n  position:relative;\n  top:10px;\n  max-width:68px;\n}\n.column1{\nwidth:100%;\n  max-width:25%;\n\n}\n@media only screen and (max-width: 800px) {\n.custom-container {\n      flex-direction: column; \n\n    }\n.column1 {\nmax-width:100% !important;\n}\n}\n</style>\n\n<div style=\"display:flex; align-items:center; justify-content:center; gap:20px !important;\" class=\"custom-container\">\n  \n  <div  class=\"column1\">\n          <div  class=\"content-block\">\n            <div class=\"icon-wrapper\">\n              <img src=\"https://cdn.shopify.com/s/files/1/2707/0176/files/ICONOmarcassudorMOVIMIENTO.gif?v=1632989458\" alt=\"\">\n            </div>\n            <div class=\"text-wrapper\">\n               <p><strong>Maximum flexibility</strong><br>\n                    Comfortable fit and made from high-quality fabrics, with durability as a priority.\n                  </p>\n            </div>\n          </div>\n        </div>\n    \n  <div class=\"column1\">\n          <div class=\"content-block\">\n            <div class=\"icon-wrapper\">\n              <img src=\"https://cdn.shopify.com/s/files/1/2707/0176/files/ICONOplanchaMOVIMIENTO.gif?v=1632989458\" alt=\"\">\n            </div>\n            <div class=\"text-wrapper\">\n               <p><strong>Wrinkle-free</strong><br>\n                   No more ironing: machine washable, hang it up, and you're done.\n                  </p>\n            </div>\n          </div>\n        </div>\n    \n  <div class=\"column1\">\n          <div class=\"content-block\">\n            <div class=\"icon-wrapper\">\n              <img src=\"https://cdn.shopify.com/s/files/1/2707/0176/files/ICONOtranspirableMOVIMIENTo.gif?v=1632989458\" alt=\"\">\n            </div>\n            <div class=\"text-wrapper\">\n               <p><strong>Breathable & Quick-drying fabric</strong><br>\n                    Fresh & comfortable all day long.\n                  </p>\n            </div>\n          </div>\n        </div>\n    \n  <div class=\"column1\">\n          <div class=\"content-block\">\n            <div class=\"icon-wrapper\">\n              <img src=\"https://cdn.shopify.com/s/files/1/2707/0176/files/ICONOantibacterianoMOVIMIENTO.gif?v=1632989458\" alt=\"\">\n            </div>\n            <div class=\"text-wrapper\">\n               <p><strong>Odor-free</strong><br>\n                    Neutralizes the bacteria that cause body odor when we sweat.\n                  </p>\n            </div>\n          </div>\n        </div>\n    \n</div>",
            "width": "100%",
            "alignment": "center"
          }
        }
